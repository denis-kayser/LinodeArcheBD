# .env.dev - Configuración para DESARROLLO
# Útil si quieres personalizar sin modificar el YML

# PostgreSQL Credentials
POSTGRES_USER=admin
POSTGRES_PASSWORD=
POSTGRES_DB=arche

# Container Configuration
CONTAINER_NAME=arche_dev
HOST_PORT=5433

# Volume Configuration (usar directorios locales para fácil limpieza)
POSTGRES_DATA_VOLUME=./postgres_data
POSTGRES_BACKUP_VOLUME=./backups

# Performance (ligero para desarrollo)
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_MAX_CONNECTIONS=50
POSTGRES_WORK_MEM=4MB

# Network
NETWORK_NAME=dev_network